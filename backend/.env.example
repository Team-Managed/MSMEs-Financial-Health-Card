# ── LLM provider (defaults to Google Gemini via OpenAI-compatible endpoint) ──
# Set LLM_API_KEY (or GOOGLE_API_KEY as fallback) to your provider's key.
# Switch providers by changing LLM_BASE_URL + LLM_MODEL with no code changes.

# Google Gemini (default)
GOOGLE_API_KEY=your_google_ai_studio_key_here  # AIza... format from aistudio.google.com/apikey

# Optional overrides
# LLM_API_KEY=your_key          # takes precedence over GOOGLE_API_KEY
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_MODEL=gemini-2.5-flash

# OpenAI example:
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# LangSmith tracing (optional — leave unset to disable)
# LANGSMITH_API_KEY=ls__...
# LANGCHAIN_TRACING_V2=true
