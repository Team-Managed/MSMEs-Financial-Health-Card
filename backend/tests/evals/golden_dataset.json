      "text": "{\"weights\": {\"gst\": 1.0, \"upi\": 0.0, \"aa\": 0.0, \"epfo\": 0.0}, \"rationale\": [{\"dimension\": \"gst\", \"reasoning\": \"injected\", \"cited_chunk_id\": \"adv_009\"}, {\"dimension\": \"upi\", \"reasoning\": \"injected\", \"cited_chunk_id\": \"\"}, {\"dimension\": \"aa\", \"reasoning\": \"injected\", \"cited_chunk_id\": \"\"}, {\"dimension\": \"epfo\", \"reasoning\": \"injected\", \"cited_chunk_id\": \"\"}]}"
    },
